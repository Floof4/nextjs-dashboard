  thread                Message?   @relation("replies", fields: [threadId], references: [id], onDelete: Cascade)
  threadMessages        Message[]  @relation("replies")
  edited                Boolean    @default(false)
  editedAt              DateTime?
  isPinned              Boolean    @default(false)
  reactions             Json?      // { "👍": ["userId1", "userId2"] }
  metadata              Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  deletedAt             DateTime?

  // Relations
  attachments           MediaFile[]
  mentions              Json?      // ["userId1", "userId2"]

  @@index([channelId])
  @@index([authorId])
  @@index([threadId])
  @@index([createdAt])
  @@map("messages")
}

model Email {
  id                    String     @id @default(cuid())
