  recipients            EmailRecipient[]
  attachments           MediaFile[]

  @@index([tenantId])
  @@index([senderId])
  @@index([status])
  @@index([sentAt])
  @@map("emails")
}

enum EmailStatus {
  DRAFT
  SCHEDULED
  SENT
  DELIVERED
  BOUNCED
  FAILED
}

model EmailRecipient {
  id                    String     @id @default(cuid())
