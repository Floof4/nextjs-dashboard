  status                IntegrationStatus @default(CONNECTED)
  config                Json       // Encrypted credentials, settings
  webhookUrl            String?
  webhookSecret         String?    // For verification
  lastSyncAt            DateTime?
  lastError             String?
  metadata              Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@unique([tenantId, provider])
  @@index([tenantId])
  @@map("integrations")
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  ERROR
  PENDING
}

model ApiKey {
  id                    String     @id @default(cuid())
  tenantId              String
  tenant                Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                  String
  key                   String     @unique @db.VarChar(255)
  secret                String?    // Optional secret
  permissions           String[]   // API scopes
  lastUsedAt            DateTime?
  expiresAt             DateTime?
  isActive              Boolean    @default(true)
  metadata              Json?
  createdAt             DateTime   @default(now())

  @@index([tenantId])
  @@index([key])
  @@map("api_keys")
}

// ============================================================================
// 20. PROCESSES & PROCEDURES
// ============================================================================

model Process {
  id                    String     @id @default(cuid())
  tenantId              String
  departmentId          String
  department            Department @relation(fields: [departmentId], references: [id], onDelete: Cascade)
  name                  String
  slug                  String
  description           String?
  steps                 Json[]     // Workflow steps
  metadata              Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@unique([departmentId, slug])
  @@index([tenantId])
  @@map("processes")
}

// ============================================================================
// 21. VERSIONS & RELEASES
// ============================================================================

model AppVersion {
  id                    String     @id @default(cuid())
  version               String     @unique
  releaseType           ReleaseType @default(MINOR)
  platform              String[]   // web, desktop, mobile
  releaseNotes          String?
  changelog             String?
  downloadUrl           String?
  checksum              String?
  size                  BigInt?
  isReleased            Boolean    @default(false)
  releasedAt            DateTime?
  isForceUpdate         Boolean    @default(false)
  metadata              Json?
  createdAt             DateTime   @default(now())

  @@map("app_versions")
}

enum ReleaseType {
  MAJOR
  MINOR
  PATCH
  HOTFIX
}

