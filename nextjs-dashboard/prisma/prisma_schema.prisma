  trigger               Json       // { type, conditions }
  actions               Json[]     // [ { type, params } ]
  metadata              Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  // Relations
  executions            AutomationExecution[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("automations")
