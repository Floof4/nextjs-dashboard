// 17. MEDIA & FILE HANDLING
// ============================================================================

model MediaFile {
  id                    String     @id @default(cuid())
  tenantId              String
  tenant                Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  userId                String
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  filename              String
  originalName          String
  mimeType              String
  size                  BigInt     // bytes
  url                   String     // CDN URL
  storageKey            String     // S3 key, local path
  storageProvider       String     @default("s3") // s3, local, gcs
  width                 Int?       // For images/videos
  height                Int?
  duration              Int?       // For videos (seconds)
  isPublic              Boolean    @default(false)
  tags                  String[]
  metadata              Json?      // EXIF, dimensions, etc.
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  deletedAt             DateTime?

  // Relations
  resourceType          String?    // Task, Comment, Email, Message, Invoice
  resourceId            String?

  // Relationships (can be attached to many resources)
  taskAttachments       Task[] @relation("attachments")
  projectAttachments    Project[] @relation("attachments")
  messageAttachments    Message[] @relation("attachments")
  emailAttachments      Email[] @relation("attachments")
  commentAttachments    Comment[] @relation("attachments")
  expenseReceipts       Expense[] @relation("receipts")
  invoiceAttachments    Invoice[] @relation("attachments")

  @@index([tenantId])
  @@index([userId])
  @@index([resourceType, resourceId])
  @@index([createdAt])
  @@map("media_files")
}

