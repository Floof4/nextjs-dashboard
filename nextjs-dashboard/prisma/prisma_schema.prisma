// ============================================================================
// ENTERPRISE MULTI-TENANT SAAS ERP/OS SCHEMA
// ============================================================================
// Database: PostgreSQL 15+
// ORM: Prisma
// Features: Multi-tenancy, RBAC/ABAC, Full audit trail, Real-time support
// ============================================================================

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

// ============================================================================
// 1. MULTI-TENANCY & CORE
// ============================================================================

model Tenant {
  id                    String     @id @default(cuid())
  name                  String
  slug                  String     @unique
  subdomain             String     @unique
  customDomain          String?    @unique
  logo                  String?
  favicon               String?
  brandColor            String     @default("#6366f1")
  accentColor           String     @default("#06b6d4")
  description           String?
  timezone              String     @default("UTC")
  language              String     @default("en")
  plan                  SubscriptionPlan @default(STARTER)
  status                TenantStatus @default(ACTIVE)
  maxUsers              Int        @default(50)
  maxProjects           Int        @default(10)
  maxStorage            BigInt     @default(5368709120) // 5GB in bytes
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  deletedAt             DateTime?

  // Relations
  users                 User[]
  workspaces            Workspace[]
  subscriptions         Subscription[]
  auditLogs             AuditLog[]
  apiKeys               ApiKey[]
  integrations          Integration[]
  customFeatures        CustomFeature[]
  mediaFiles            MediaFile[]
  invitations           Invitation[]

  @@index([slug])
  @@index([customDomain])
  @@map("tenants")
}

enum SubscriptionPlan {
  STARTER
  PROFESSIONAL
  ENTERPRISE
  CUSTOM
}

enum TenantStatus {
  ACTIVE
  PAUSED
  CANCELLED
  SUSPENDED
}

model Subscription {
  id                    String     @id @default(cuid())
  tenantId              String
  tenant                Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  plan                  SubscriptionPlan
  status                String     @default("active")
  currentPeriodStart    DateTime
  currentPeriodEnd      DateTime
  cancelledAt           DateTime?
  price                 Decimal    @db.Decimal(10, 2)
  currency              String     @default("USD")
  billingEmail          String
  metadata              Json?      // Custom fields
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@unique([tenantId])
  @@index([tenantId])
  @@map("subscriptions")
}

model CustomFeature {
  id                    String     @id @default(cuid())
  tenantId              String
  tenant                Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  featureKey            String
  featureName           String
  isEnabled             Boolean    @default(true)
  metadata              Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@unique([tenantId, featureKey])
  @@map("custom_features")
}

model Workspace {
  id                    String     @id @default(cuid())
  tenantId              String
  tenant                Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  name                  String
  description           String?
  icon                  String?
  isDefault             Boolean    @default(false)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  // Relations
  departments           Department[]
  members               WorkspaceMember[]

  @@unique([tenantId, name])
  @@index([tenantId])
  @@map("workspaces")
}

model WorkspaceMember {
  id                    String     @id @default(cuid())
  workspaceId           String
  workspace             Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  userId                String
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  joinedAt              DateTime   @default(now())

  @@unique([workspaceId, userId])
  @@index([workspaceId])
  @@index([userId])
  @@map("workspace_members")
}

// ============================================================================
// 2. USERS & AUTHENTICATION
// ============================================================================

model User {
  id                    String     @id @default(cuid())
  tenantId              String
  tenant                Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email                 String
  emailVerified         DateTime?
  password              String?    // Nullable for OAuth users
  firstName             String?
  lastName              String?
  displayName           String?
  avatar                String?
  phone                 String?
  timezone              String?
  language              String?    @default("en")
  status                UserStatus @default(ACTIVE)
  role                  String?    // Primary role (can have multiple via UserRole)
  department            String?
  title                 String?
  manager               String?    // ManagerId (self-reference)
  bio                   String?
  lastLoginAt           DateTime?
  lastActivityAt        DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  deletedAt             DateTime?

  // Profile customization
  profileBannerTheme    String     @default("default") // 10 themes
  profileAccentColor    String     @default("blue") // 8 colors
  profileBannerUrl      String?

  // Two-factor
  totpSecret            String?
  totpEnabled           Boolean    @default(false)
  backupCodes           String[]   @default([])

  // Preferences
  preferences           UserPreferences?
  notificationSettings  NotificationSettings?

  // Relations
  workspaces            WorkspaceMember[]
  userRoles             UserRole[]
  userPermissions       UserPermission[]
  userAttributes        UserAttribute[]
  sessions              Session[]
  attendanceRecords     AttendanceRecord[]
  tasks                 Task[] @relation("assignee")
  taskCreator           Task[] @relation("creator")
  projects              ProjectMember[]
  messages              Message[]
  comments              Comment[]
  feed                  FeedPost[]
  emailsSent            Email[] @relation("sender")
  emailsTo              EmailRecipient[]
  calendars             Calendar[]
  events                CalendarEvent[] @relation("organizer")
  eventParticipants     EventParticipant[]
  leaves                LeaveRequest[]
  payrollRecords        PayrollRecord[]
  performanceReviews    PerformanceReview[]
  formResponses         FormResponse[]
  automationExecutions  AutomationExecution[]
  invoices              Invoice[] @relation("creator")
  expenses              Expense[]
  budgets               Budget[] @relation("owner")
  proposals             Proposal[]
  clientRelations       ClientRelationship[]
  tickets               Ticket[] @relation("assignee")
  ticketCreator         Ticket[] @relation("creator")
  createdApprovals      Approval[] @relation("createdBy")
  approvalActions       Approval[] @relation("approver")
  mediaFiles            MediaFile[]
  clientPortalAccess    ClientPortalUser?

  @@unique([tenantId, email])
  @@index([tenantId])
  @@index([status])
  @@map("users")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}

model UserPreferences {
  id                    String     @id @default(cuid())
  userId                String     @unique
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  theme                 String     @default("light") // light, dark, auto
  compactMode           Boolean    @default(false)
  sidebarCollapsed      Boolean    @default(false)
  defaultView           String?    // dashboard, projects, tasks, etc.
  autoClockOut          Boolean    @default(true)
  soundNotifications    Boolean    @default(true)
  emailNotifications    Boolean    @default(true)
  desktopNotifications  Boolean    @default(true)
  hideOfflineUsers      Boolean    @default(false)
  metadata              Json?
  updatedAt             DateTime   @updatedAt

  @@map("user_preferences")
}

model NotificationSettings {
  id                    String     @id @default(cuid())
  userId                String     @unique
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  email                 Boolean    @default(true)
  push                  Boolean    @default(true)
  inApp                 Boolean    @default(true)
  slack                 Boolean    @default(false)
  mentions              Boolean    @default(true)
  comments              Boolean    @default(true)
  taskAssignments       Boolean    @default(true)
  projectUpdates        Boolean    @default(true)
  dailyDigest           Boolean    @default(false)
  digestTime            String?    // "09:00"
  mutedUntil            DateTime?
  updatedAt             DateTime   @updatedAt

  @@map("notification_settings")
}

model Session {
  id                    String     @id @default(cuid())
  userId                String
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken          String     @unique
  expires               DateTime
  userAgent             String?
  ipAddress             String?
  deviceType            String?    // web, mobile, desktop
  lastActivityAt        DateTime   @default(now())
  createdAt             DateTime   @default(now())

  @@index([userId])
  @@index([sessionToken])
  @@map("sessions")
}

model Invitation {
  id                    String     @id @default(cuid())
  tenantId              String
  tenant                Tenant     @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  email                 String
  token                 String     @unique
  role                  String
  expiresAt             DateTime
  createdAt             DateTime   @default(now())
  acceptedAt            DateTime?
  rejectedAt            DateTime?

  @@unique([tenantId, email])
  @@index([tenantId])
  @@map("invitations")
}

// ============================================================================
// 3. RBAC (ROLE-BASED ACCESS CONTROL)
// ============================================================================

model Role {
  id                    String     @id @default(cuid())
  tenantId              String
  name                  String
  slug                  String
  description           String?
  color                 String?
  isSystem              Boolean    @default(false) // system roles: admin, user, client
  isCustom              Boolean    @default(false)
  priority              Int        @default(0) // higher = more permissions
  metadata              Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  // Relations
  permissions           RolePermission[]
  users                 UserRole[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("roles")
}

model UserRole {
  id                    String     @id @default(cuid())
  userId                String
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId                String
  role                  Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedAt            DateTime   @default(now())
  expiresAt             DateTime?  // Temporary role assignment

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model Permission {
  id                    String     @id @default(cuid())
  tenantId              String
  name                  String
  slug                  String
  description           String?
  module                String     // hr, finance, projects, crm, etc.
  action                String     // create, read, update, delete
  resource              String     // User, Project, Invoice, etc.
  createdAt             DateTime   @default(now())

  // Relations
  roles                 RolePermission[]
  users                 UserPermission[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@index([module])
  @@map("permissions")
}

model RolePermission {
  id                    String     @id @default(cuid())
  roleId                String
  role                  Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId          String
  permission            Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@map("role_permissions")
}

// Direct permission override (for specific users)
model UserPermission {
  id                    String     @id @default(cuid())
  userId                String
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionId          String
  permission            Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  granted               Boolean    @default(true)
  expiresAt             DateTime?

  @@unique([userId, permissionId])
  @@index([userId])
  @@map("user_permissions")
}

// ============================================================================
// 4. ABAC (ATTRIBUTE-BASED ACCESS CONTROL)
// ============================================================================

model UserAttribute {
  id                    String     @id @default(cuid())
  userId                String
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  attributeKey          String
  attributeValue        String
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@unique([userId, attributeKey])
  @@index([userId])
  @@map("user_attributes")
}

model ResourceAttribute {
  id                    String     @id @default(cuid())
  resourceType          String     // Project, Task, Invoice
  resourceId            String
  attributeKey          String
  attributeValue        String
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@unique([resourceType, resourceId, attributeKey])
  @@index([resourceType, resourceId])
  @@map("resource_attributes")
}

model AccessRule {
  id                    String     @id @default(cuid())
  tenantId              String
  name                  String
  description           String?
  effect                String     @default("ALLOW") // ALLOW, DENY
  conditions            Json       // { "department": "sales", "level": { "gte": 3 } }
  actions               String[]   // ["read", "update"]
  resources             String[]   // ["Project", "Task"]
  priority              Int        @default(0)
  isActive              Boolean    @default(true)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@index([tenantId])
  @@map("access_rules")
}

// ============================================================================
// 5. ORGANIZATION & HR
// ============================================================================

model Department {
  id                    String     @id @default(cuid())
  workspaceId           String
  workspace             Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name                  String
  slug                  String
  description           String?
  headId                String?
  budget                Decimal    @db.Decimal(15, 2)
  color                 String?
  parentId              String?
  parent                Department? @relation("subdepartments", fields: [parentId], references: [id])
  children              Department[] @relation("subdepartments")
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  // Relations
  employees             Employee[]
  processes             Process[]

  @@unique([workspaceId, slug])
  @@index([workspaceId])
  @@map("departments")
}

model Employee {
  id                    String     @id @default(cuid())
  userId                String
  departmentId          String
  department            Department @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  employeeId            String     @unique
  employmentStatus      EmploymentStatus @default(ACTIVE)
  employmentType        EmploymentType   @default(FULL_TIME)
  joinDate              DateTime
  exitDate              DateTime?
  salary                Decimal    @db.Decimal(15, 2)
  salaryType            SalaryType @default(MONTHLY)
  bankAccount           String?    // Encrypted
  bankCode              String?
  bankName              String?
  taxId                 String?
  emergencyContact      String?
  emergencyPhone        String?
  certifications        String[]
  skills                String[]
  metadata              Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  // Relations
  leaves                LeaveRequest[]
  payroll               PayrollRecord[]
  reviews               PerformanceReview[]

  @@index([departmentId])
  @@map("employees")
}

enum EmploymentStatus {
  ACTIVE
  PROBATION
  CONTRACT
  LEAVE
  TERMINATED
}

enum EmploymentType {
  FULL_TIME
  PART_TIME
  CONTRACT
  FREELANCE
  INTERN
}

enum SalaryType {
  HOURLY
  DAILY
  WEEKLY
  MONTHLY
  ANNUALLY
}

model LeaveRequest {
  id                    String     @id @default(cuid())
  userId                String
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  employeeId            String
  employee              Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  leaveType             LeaveType
  startDate             DateTime
  endDate               DateTime
  days                  Int
  reason                String?
  status                ApprovalStatus @default(PENDING)
  approvedBy            String?
  approvedAt            DateTime?
  rejectionReason       String?
  metadata              Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@index([userId])
  @@index([status])
  @@map("leave_requests")
}

enum LeaveType {
  ANNUAL
  SICK
  MATERNITY
  PATERNITY
  UNPAID
  OTHER
}

model AttendanceRecord {
  id                    String     @id @default(cuid())
  userId                String
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  date                  DateTime
  clockInTime           DateTime?
  clockOutTime          DateTime?
  duration              Int?       // minutes
  status                AttendanceStatus @default(PRESENT)
  location              String?    // office, remote, hybrid
  notes                 String?
  metadata              Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@unique([userId, date])
  @@index([userId])
  @@index([date])
  @@map("attendance_records")
}

enum AttendanceStatus {
  PRESENT
  ABSENT
  LATE
  HALF_DAY
  ON_LEAVE
  WEEKEND
  HOLIDAY
}

model PayrollRecord {
  id                    String     @id @default(cuid())
  employeeId            String
  employee              Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  payrollMonth          DateTime
  baseSalary            Decimal    @db.Decimal(15, 2)
  allowances            Decimal    @db.Decimal(15, 2) @default(0)
  deductions            Decimal    @db.Decimal(15, 2) @default(0)
  tax                   Decimal    @db.Decimal(15, 2) @default(0)
  netSalary             Decimal    @db.Decimal(15, 2)
  status                PayrollStatus @default(DRAFT)
  processedAt           DateTime?
  paidAt                DateTime?
  metadata              Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@unique([employeeId, payrollMonth])
  @@index([employeeId])
  @@index([status])
  @@map("payroll_records")
}

enum PayrollStatus {
  DRAFT
  SUBMITTED
  APPROVED
  PROCESSED
  PAID
  DISPUTED
}

model PerformanceReview {
  id                    String     @id @default(cuid())
  employeeId            String
  employee              Employee   @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  reviewerId            String
  reviewer              User       @relation(fields: [reviewerId], references: [id], onDelete: Cascade)
  period                String     // Q1, Q2, Q3, Q4, Annual
  year                  Int
  rating                Int        // 1-5
  comments              String?
  goals                 String[]
  strengths             String[]
  improvements          String[]
  status                ReviewStatus @default(DRAFT)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@index([employeeId])
  @@map("performance_reviews")
}

enum ReviewStatus {
  DRAFT
  SUBMITTED
  REVIEWED
  COMPLETED
}

// ============================================================================
// 6. PROJECTS & TASKS
// ============================================================================

model Project {
  id                    String     @id @default(cuid())
  tenantId              String
  workspaceId           String
  workspace             Workspace  @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  name                  String
  slug                  String
  description           String?
  status                ProjectStatus @default(PLANNING)
  visibility            ProjectVisibility @default(PRIVATE)
  type                  ProjectType @default(GENERAL)
  startDate             DateTime?
  endDate               DateTime?
  budget                Decimal?   @db.Decimal(15, 2)
  spent                 Decimal    @db.Decimal(15, 2) @default(0)
  progress              Int        @default(0)
  priority              Priority   @default(MEDIUM)
  leadId                String?
  ownerId               String?
  parentId              String?
  parent                Project?   @relation("subprojects", fields: [parentId], references: [id], onDelete: SetNull)
  children              Project[]  @relation("subprojects")
  repositoryUrl         String?
  documentationUrl      String?
  metadata              Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  deletedAt             DateTime?

  // Relations
  members               ProjectMember[]
  tasks                 Task[]
  sprints               Sprint[]
  comments              Comment[]
  attachments           MediaFile[]

  @@unique([workspaceId, slug])
  @@index([tenantId])
  @@index([workspaceId])
  @@index([status])
  @@map("projects")
}

enum ProjectStatus {
  PLANNING
  DESIGN
  DEVELOPMENT
  TESTING
  DEPLOYMENT
  MAINTENANCE
  ARCHIVED
  CANCELLED
}

enum ProjectVisibility {
  PRIVATE
  TEAM
  PUBLIC
}

enum ProjectType {
  GENERAL
  WEB_APP
  MOBILE_APP
  LANDING_PAGE
  MICROSITE
  API
  INTERNAL_TOOL
  CLIENT_PROJECT
}

model ProjectMember {
  id                    String     @id @default(cuid())
  projectId             String
  project               Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  userId                String
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  role                  ProjectRole @default(MEMBER)
  joinedAt              DateTime   @default(now())

  @@unique([projectId, userId])
  @@index([projectId])
  @@map("project_members")
}

enum ProjectRole {
  OWNER
  LEAD
  MEMBER
  VIEWER
  CONTRIBUTOR
}

model Sprint {
  id                    String     @id @default(cuid())
  projectId             String
  project               Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  name                  String
  status                SprintStatus @default(PLANNING)
  startDate             DateTime?
  endDate               DateTime?
  goal                  String?
  capacity              Int?       // story points
  metadata              Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  // Relations
  tasks                 Task[]

  @@unique([projectId, name])
  @@index([projectId])
  @@map("sprints")
}

enum SprintStatus {
  PLANNING
  ACTIVE
  COMPLETED
  CLOSED
}

model Task {
  id                    String     @id @default(cuid())
  projectId             String?
  project               Project?   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sprintId              String?
  sprint                Sprint?    @relation(fields: [sprintId], references: [id], onDelete: SetNull)
  title                 String
  slug                  String
  description           String?
  status                TaskStatus @default(TODO)
  priority              Priority   @default(MEDIUM)
  type                  TaskType   @default(TASK)
  creatorId             String
  creator               User       @relation("creator", fields: [creatorId], references: [id], onDelete: Cascade)
  assigneeId            String?
  assignee              User?      @relation("assignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  storyPoints           Int?
  estimatedHours        Decimal?   @db.Decimal(8, 2)
  actualHours           Decimal?   @db.Decimal(8, 2)
  dueDate               DateTime?
  startDate             DateTime?
  completedAt           DateTime?
  parentId              String?
  parent                Task?      @relation("subtasks", fields: [parentId], references: [id], onDelete: Cascade)
  subtasks              Task[]     @relation("subtasks")
  priority              Priority   @default(MEDIUM)
  labels                String[]
  metadata              Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  deletedAt             DateTime?

  // Relations
  comments              Comment[]
  attachments           MediaFile[]

  @@unique([projectId, slug])
  @@index([projectId])
  @@index([sprintId])
  @@index([status])
  @@index([assigneeId])
  @@map("tasks")
}

enum TaskStatus {
  TODO
  BACKLOG
  IN_PROGRESS
  IN_REVIEW
  TESTING
  BLOCKED
  COMPLETED
  CANCELLED
}

enum TaskType {
  TASK
  BUG
  FEATURE
  IMPROVEMENT
  DOCUMENTATION
  SPIKE
}

enum Priority {
  URGENT
  HIGH
  MEDIUM
  LOW
  MINIMAL
}

// ============================================================================
// 7. CALENDAR & EVENTS
// ============================================================================

model Calendar {
  id                    String     @id @default(cuid())
  userId                String
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  name                  String
  description           String?
  color                 String
  isDefault             Boolean    @default(false)
  isPublic              Boolean    @default(false)
  timezone              String?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  // Relations
  events                CalendarEvent[]

  @@unique([userId, name])
  @@index([userId])
  @@map("calendars")
}

model CalendarEvent {
  id                    String     @id @default(cuid())
  calendarId            String
  calendar              Calendar   @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  title                 String
  description           String?
  startTime             DateTime
  endTime               DateTime
  isAllDay              Boolean    @default(false)
  location              String?
  organizer             User       @relation("organizer", fields: [organizerId], references: [id], onDelete: Cascade)
  organizerId           String
  visibility            EventVisibility @default(PRIVATE)
  reminder              Int?       // minutes before
  type                  EventType  @default(MEETING)
  recurrence            Json?      // rrule
  externalId            String?    // Google Calendar, Outlook, etc.
  metadata              Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  deletedAt             DateTime?

  // Relations
  participants          EventParticipant[]
  comments              Comment[]

  @@index([calendarId])
  @@index([startTime])
  @@map("calendar_events")
}

enum EventVisibility {
  PRIVATE
  SHARED
  PUBLIC
}

enum EventType {
  MEETING
  STANDUP
  PRESENTATION
  CONFERENCE
  DEADLINE
  MILESTONE
  OTHER
