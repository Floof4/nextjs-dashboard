  responses             FormResponse[]

  @@unique([tenantId, slug])
  @@index([tenantId])
  @@map("forms")
}

enum FormStatus {
  DRAFT
  PUBLISHED
  CLOSED
  ARCHIVED
}

model FormField {
  id                    String     @id @default(cuid())
  formId                String
  form                  Form       @relation(fields: [formId], references: [id], onDelete: Cascade)
  name                  String
  type                  String     // text, email, number, date, select, checkbox
  label                 String
  required              Boolean    @default(false)
  placeholder           String?
  description           String?
  options               String[]   // For select/checkbox
  validation            Json?
  order                 Int
  metadata              Json?

  @@index([formId])
  @@map("form_fields")
}

model FormResponse {
  id                    String     @id @default(cuid())
  formId                String
  form                  Form       @relation(fields: [formId], references: [id], onDelete: Cascade)
