// ============================================================================
// ENTERPRISE MULTI-TENANT SAAS ERP/OS SCHEMA
// ============================================================================
// Database: PostgreSQL 15+
// ORM: Prisma
// Features: Multi-tenancy, RBAC/ABAC, Full audit trail, Real-time support
// ============================================================================

datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

// ============================================================================
// 2. USERS & AUTHENTICATION
// ============================================================================

model User {
  id                    String     @id @default(cuid())
  email                 String
  emailVerified         DateTime?
  password              String?    // Nullable for OAuth users
  firstName             String?
  lastName              String?
  displayName           String?
  avatar                String?
  phone                 String?
  timezone              String?
  language              String?    @default("en")
  status                UserStatus @default(ACTIVE)
  role                  String?    // Primary role (can have multiple via UserRole)
  department            String?
  title                 String?
  manager               String?    // ManagerId (self-reference)
  bio                   String?
  lastLoginAt           DateTime?
  lastActivityAt        DateTime?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt
  deletedAt             DateTime?

  // Profile customization
  profileBannerTheme    String     @default("default") // 10 themes
  profileAccentColor    String     @default("blue") // 8 colors
  profileBannerUrl      String?

  // Two-factor
  totpSecret            String?
  totpEnabled           Boolean    @default(false)
  backupCodes           String[]   @default([])

  // Relations
  userRoles             UserRole[]
  userPermissions       UserPermission[]
  userAttributes        UserAttribute[]
  sessions              Session[]

  @@index([status])
  @@map("users")
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  DELETED
}


model Session {
  id                    String     @id @default(cuid())
  userId                String
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  sessionToken          String     @unique
  expires               DateTime
  userAgent             String?
  ipAddress             String?
  deviceType            String?    // web, mobile, desktop
  lastActivityAt        DateTime   @default(now())
  createdAt             DateTime   @default(now())

  @@index([userId])
  @@index([sessionToken])
  @@map("sessions")
}

// ============================================================================
// 3. RBAC (ROLE-BASED ACCESS CONTROL)
// ============================================================================

model Role {
  id                    String     @id @default(cuid())
  userId              String
  name                  String
  slug                  String
  description           String?
  color                 String?
  isSystem              Boolean    @default(false) // system roles: admin, user, client
  isCustom              Boolean    @default(false)
  priority              Int        @default(0) // higher = more permissions
  metadata              Json?
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  // Relations
  permissions           RolePermission[]
  users                 UserRole[]

  @@unique([userId, slug])
  @@index([userId])
  @@map("roles")
}

model UserRole {
  id                    String     @id @default(cuid())
  userId                String
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  roleId                String
  role                  Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  assignedAt            DateTime   @default(now())
  expiresAt             DateTime?  // Temporary role assignment

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
  @@map("user_roles")
}

model Permission {
  id                    String     @id @default(cuid())
  userId              String
  name                  String
  slug                  String
  description           String?
  module                String     // hr, finance, projects, crm, etc.
  action                String     // create, read, update, delete
  resource              String     // User, Project, Invoice, etc.
  createdAt             DateTime   @default(now())

  // Relations
  roles                 RolePermission[]
  users                 UserPermission[]

  @@unique([userId, slug])
  @@index([userId])
  @@index([module])
  @@map("permissions")
}

model RolePermission {
  id                    String     @id @default(cuid())
  roleId                String
  role                  Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permissionId          String
  permission            Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
  @@index([roleId])
  @@map("role_permissions")
}

// Direct permission override (for specific users)
model UserPermission {
  id                    String     @id @default(cuid())
  userId                String
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  permissionId          String
  permission            Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)
  granted               Boolean    @default(true)
  expiresAt             DateTime?

  @@unique([userId, permissionId])
  @@index([userId])
  @@map("user_permissions")
}

// ============================================================================
// 4. ABAC (ATTRIBUTE-BASED ACCESS CONTROL)
// ============================================================================

model UserAttribute {
  id                    String     @id @default(cuid())
  userId                String
  user                  User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  attributeKey          String
  attributeValue        String
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@unique([userId, attributeKey])
  @@index([userId])
  @@map("user_attributes")
}

model ResourceAttribute {
  id                    String     @id @default(cuid())
  resourceType          String     // Project, Task, Invoice
  resourceId            String
  attributeKey          String
  attributeValue        String
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@unique([resourceType, resourceId, attributeKey])
  @@index([resourceType, resourceId])
  @@map("resource_attributes")
}

model AccessRule {
  id                    String     @id @default(cuid())
  tenantId              String
  name                  String
  description           String?
  effect                String     @default("ALLOW") // ALLOW, DENY
  conditions            Json       // { "department": "sales", "level": { "gte": 3 } }
  actions               String[]   // ["read", "update"]
  resources             String[]   // ["Project", "Task"]
  priority              Int        @default(0)
  isActive              Boolean    @default(true)
  createdAt             DateTime   @default(now())
  updatedAt             DateTime   @updatedAt

  @@index([tenantId])
  @@map("access_rules")
}

